generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ═══════════════════════════════════
// UTILISATEURS & AUTH
// ═══════════════════════════════════

enum UserRole {
  SEARCHER
  INVESTOR
  SELLER
  ADMIN
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id                 String             @id @default(cuid())
  email              String             @unique
  emailVerified      DateTime?
  name               String?
  image              String?
  role               UserRole           @default(SEARCHER)
  verificationStatus VerificationStatus @default(UNVERIFIED)
  linkedinUrl        String?
  bio                String?            @db.Text
  languages          String[]
  country            String?
  city               String?

  accounts    Account[]
  sessions    Session[]

  searcherProfile SearcherProfile?
  investorProfile InvestorProfile?
  sellerProfile   SellerProfile?
  listings        Listing[]

  sentMessages     Message[] @relation("sender")
  receivedMessages Message[] @relation("receiver")

  sentConnections     Connection[] @relation("requester")
  receivedConnections Connection[] @relation("receiver")

  notifications Notification[]
  savedListings SavedListing[]
  forumPosts    ForumPost[]
  forumComments ForumComment[]
  inquiries     Inquiry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ═══════════════════════════════════
// PROFILS
// ═══════════════════════════════════

enum SearchType {
  TRADITIONAL
  SELF_FUNDED
  ACCELERATOR
  INDEPENDENT_SPONSOR
}

enum SearchStatus {
  PREPARING
  RAISING_CAPITAL
  ACTIVELY_SEARCHING
  LOI_SIGNED
  ACQUIRED
  OPERATING
  EXITED
}

model SearcherProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  searchType          SearchType   @default(SELF_FUNDED)
  searchStatus        SearchStatus @default(PREPARING)
  mbaSchool           String?
  targetSectors       String[]
  targetCountries     String[]
  targetEbitdaMin     Int?
  targetEbitdaMax     Int?
  targetRevenueMin    Int?
  targetRevenueMax    Int?
  acquisitionTimeline String?
  thesisDescription   String?      @db.Text

  seekingCapital Boolean @default(true)
  capitalNeeded  Int?

  isPublic Boolean @default(true)
  headline String?
  slug     String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum InvestorType {
  EX_SEARCHER
  FAMILY_OFFICE
  INSTITUTIONAL
  ANGEL
  ACCELERATOR
}

model InvestorProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  investorType         InvestorType
  firmName             String?
  firmWebsite          String?
  ticketSizeMin        Int?
  ticketSizeMax        Int?
  targetSectors        String[]
  targetCountries      String[]
  preferredSearchTypes SearchType[]
  preferredEbitdaMin   Int?
  preferredEbitdaMax   Int?
  totalDealsInvested   Int?         @default(0)
  valueAdd             String[]

  isPublic        Boolean @default(true)
  headline        String?
  slug            String? @unique
  investmentThesis String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SellerProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  companyRole String?
  isPublic    Boolean @default(true)
  headline    String?
  slug        String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ═══════════════════════════════════
// ANNONCES (LISTINGS)
// ═══════════════════════════════════

enum ListingStatus {
  DRAFT
  UNDER_REVIEW
  ACTIVE
  UNDER_LOI
  SOLD
  WITHDRAWN
}

model Listing {
  id       String @id @default(cuid())
  sellerId String
  seller   User   @relation(fields: [sellerId], references: [id])

  title       String
  slug        String  @unique
  sector      String
  subSector   String?
  country     String
  region      String?
  currency    String  @default("EUR")

  revenue        Int?
  ebitda         Int?
  ebitdaMargin   Float?
  askingPrice    Int?
  askingMultiple Float?
  employeeCount  Int?
  yearFounded    Int?

  summary     String   @db.Text
  description String?  @db.Text
  highlights  String[]

  reasonForSale   String?
  sellerFinancing Boolean? @default(false)
  timeline        String?

  status      ListingStatus @default(DRAFT)
  imageUrl    String?
  metaDescription String?

  savedBy   SavedListing[]
  inquiries Inquiry[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  publishedAt DateTime?

  @@index([status, country, sector])
  @@index([status, ebitda])
  @@index([status, revenue])
  @@index([publishedAt])
}

model Inquiry {
  id        String   @id @default(cuid())
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  message   String   @db.Text
  createdAt DateTime @default(now())

  @@unique([listingId, userId])
}

model SavedListing {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id])
  note      String?
  createdAt DateTime @default(now())

  @@unique([userId, listingId])
}

// ═══════════════════════════════════
// CONNECTIONS & MESSAGING
// ═══════════════════════════════════

enum ConnectionStatus {
  PENDING
  ACCEPTED
  DECLINED
}

model Connection {
  id          String           @id @default(cuid())
  requesterId String
  requester   User             @relation("requester", fields: [requesterId], references: [id])
  receiverId  String
  receiver    User             @relation("receiver", fields: [receiverId], references: [id])
  status      ConnectionStatus @default(PENDING)
  message     String?          @db.Text
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([requesterId, receiverId])
}

model Conversation {
  id           String    @id @default(cuid())
  participant1 String
  participant2 String
  messages     Message[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([participant1, participant2])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  senderId       String
  sender         User         @relation("sender", fields: [senderId], references: [id])
  receiverId     String
  receiver       User         @relation("receiver", fields: [receiverId], references: [id])
  content        String       @db.Text
  readAt         DateTime?
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
}

// ═══════════════════════════════════
// NOTIFICATIONS
// ═══════════════════════════════════

enum NotificationType {
  CONNECTION_REQUEST
  CONNECTION_ACCEPTED
  NEW_MESSAGE
  NEW_LISTING
  INQUIRY_RECEIVED
  SYSTEM
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id])
  type      NotificationType
  title     String
  message   String
  link      String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId, read])
}

// ═══════════════════════════════════
// FORUM
// ═══════════════════════════════════

model ForumCategory {
  id          String      @id @default(cuid())
  name        String
  slug        String      @unique
  description String?
  sortOrder   Int         @default(0)
  posts       ForumPost[]
}

model ForumPost {
  id         String         @id @default(cuid())
  title      String
  slug       String         @unique
  content    String         @db.Text
  authorId   String
  author     User           @relation(fields: [authorId], references: [id])
  categoryId String
  category   ForumCategory  @relation(fields: [categoryId], references: [id])
  isPinned   Boolean        @default(false)
  viewCount  Int            @default(0)
  comments   ForumComment[]
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
}

model ForumComment {
  id        String    @id @default(cuid())
  content   String    @db.Text
  authorId  String
  author    User      @relation(fields: [authorId], references: [id])
  postId    String
  post      ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  parentId  String?
  createdAt DateTime  @default(now())
}
